{
  "name": "docxodus-ts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript port of the Docxodus DocxDiff IR engine (1:1 port of Docxodus/Ir + Ir/Diff; see ../docs/architecture/ir_diff_engine.md). Verified differentially against the C# WASM engine via deterministic edit-script JSON.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "fflate": "^0.8.2",
    "saxes": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "docxodus": "workspace:*",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
