{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "nodenext",
    "module": "nodenext"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*.ts"]
}
